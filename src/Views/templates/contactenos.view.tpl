<!-- ============================================================
     SECCIÓN PRINCIPAL — Info + Formulario
     ============================================================ -->
<section class="contacto-main">
    <div class="contacto-grid">

        <!-- Columna izquierda: info de contacto -->
        <div class="contacto-info">
            <h3>Ponte en Contacto</h3>
            <p class="contacto-subtitulo">Visítanos, llámanos o escríbenos. Con gusto te atendemos!</p>

            <!-- Tarjetas de contacto -->
            <div class="contacto-tarjetas">
                <div class="contacto-tarjeta activa">
                    <span class="contacto-icono">
                        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .18h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
                        </svg>
                    </span>
                    <div>
                        <strong>Teléfono</strong>
                        <p>{{telefono}}</p>
                    </div>
                </div>

                <div class="contacto-tarjeta">
                    <span class="contacto-icono">
                        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
                        </svg>
                    </span>
                    <div>
                        <strong>Correo</strong>
                        <p>{{email}}</p>
                    </div>
                </div>

                <div class="contacto-tarjeta">
                    <span class="contacto-icono">
                        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
                        </svg>
                    </span>
                    <div>
                        <strong>Dirección</strong>
                        <p>{{direccion}}</p>
                    </div>
                </div>

                <div class="contacto-tarjeta activa">
                    <span class="contacto-icono">
                        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                        </svg>
                    </span>
                    <div>
                        <strong>Horario</strong>
                        <p>Lunes a Sábado: 8am – 6pm</p>
                    </div>
                </div>
            </div>

            <!-- Redes sociales -->
            <div class="contacto-redes">
                <h4>Síguenos en redes sociales</h4>
                <p class="contacto-subtitulo">Encuentra inspiración floral y nuestras últimas creaciones.</p>
                <div class="redes-iconos">
                    <a href="https://www.facebook.com/people/Florister%C3%ADa-Promesa-De-Dios/61551369051785/" target="_blank" class="red-icono red-facebook" title="Facebook">
                        <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
                            <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
                        </svg>
                        <span>{{facebook}}</span>
                    </a>
                    <a href="https://www.instagram.com/floristeria_promesa_de_dios_07/?hl=es" target="_blank" class="red-icono red-instagram" title="Instagram">
                        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                        </svg>
                        <span>@{{instagram}}</span>
                    </a>
                    <a href="https://www.tiktok.com/@promesa_de_dios_hn" target="_blank" class="red-icono red-tiktok" title="TikTok">
                        <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
                            <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.3 6.3 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.75a4.85 4.85 0 01-1.01-.06z"/>
                        </svg>
                        <span>@{{tiktok}}</span>
                    </a>
                </div>
            </div>
        </div>

        <!-- Columna derecha: formulario con imagen de fondo -->
        <div class="contacto-formulario-wrap">
            <div class="contacto-formulario-bg">
                <img src="{{~BASE_DIR}}public/imgs/hero/4.jpg" alt="Fondo formulario" />
                <div class="contacto-formulario-overlay"></div>
            </div>
            <form class="contacto-form" action="#" method="POST">
                <input type="text" name="nombre" placeholder="Tu nombre completo" required />
                <input type="email" name="email" placeholder="Tu correo electrónico" required />
                <input type="tel" name="telefono" placeholder="Tu número de teléfono" />
                <textarea name="mensaje" rows="5" placeholder="¿En qué podemos ayudarte?" required></textarea>
                <button type="submit" class="flor-btn">Enviar Mensaje</button>
            </form>
        </div>

    </div>
</section>


