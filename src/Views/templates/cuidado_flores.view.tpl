<section class="cuidado-page">

    <!-- HERO -->
    <section class="flor-hero herocontainer">
        <img src="https://images.pexels.com/photos/5410137/pexels-photo-5410137.jpeg" alt="Cuidado de las flores" />
        <div class="flor-hero-content">
            <h2>{{titulo}}</h2>
            <p>
                Cada arreglo floral tiene su propia esencia. Aprende a cuidar las flores
                que vendemos para que duren hermosas por más tiempo.
            </p>
        </div>
    </section>

    <!-- Borde decorativo abajo -->
